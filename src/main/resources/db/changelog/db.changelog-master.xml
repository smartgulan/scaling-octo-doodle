<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <include file="db/changelog/migrations/2026-03-21-create-initial-scheme.sql"/>

    <changeSet id="precondition-uc-music-types" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uc_music_types_name" tableName="music_types"/></not>
        </preConditions>
        <addUniqueConstraint columnNames="name"
                             constraintName="uc_music_types_name"
                             tableName="music_types"/>
    </changeSet>

    <changeSet id="precondition-uc-users-email" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uc_users_email" tableName="users"/></not>
        </preConditions>
        <addUniqueConstraint columnNames="email"
                             constraintName="uc_users_email"
                             tableName="users"/>
    </changeSet>

    <changeSet id="precondition-fk-stores-user" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="FK_STORES_ON_USER" foreignKeyTableName="stores"/></not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="stores"
                                 constraintName="FK_STORES_ON_USER"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

    <changeSet id="precondition-fk-users-music-type" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="FK_USERS_ON_MUSIC_TYPE" foreignKeyTableName="users"/></not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="music_type_id"
                                 baseTableName="users"
                                 constraintName="FK_USERS_ON_MUSIC_TYPE"
                                 referencedColumnNames="id"
                                 referencedTableName="music_types"/>
    </changeSet>

    <changeSet id="precondition-fk-jinsto-on-jingle" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="fk_jinsto_on_jingle" foreignKeyTableName="jingle_stores"/></not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="jingle_id"
                                 baseTableName="jingle_stores"
                                 constraintName="fk_jinsto_on_jingle"
                                 referencedColumnNames="id"
                                 referencedTableName="jingles"/>
    </changeSet>

    <changeSet id="precondition-fk-jinsto-on-store" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="fk_jinsto_on_store" foreignKeyTableName="jingle_stores"/></not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="store_id"
                                 baseTableName="jingle_stores"
                                 constraintName="fk_jinsto_on_store"
                                 referencedColumnNames="id"
                                 referencedTableName="stores"/>
    </changeSet>

</databaseChangeLog>