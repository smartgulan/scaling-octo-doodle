<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1773986686936-1" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="email_verification_tokens"/></not>
        </preConditions>
        <createTable tableName="email_verification_tokens">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_email_verification_tokens"/>
            </column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="token" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="expiry_date" type="DATETIME"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-2" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="jingle_stores"/></not>
        </preConditions>
        <createTable tableName="jingle_stores">
            <column name="jingle_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_jingle_stores"/>
            </column>
            <column name="store_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_jingle_stores"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-3" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="jingles"/></not>
        </preConditions>
        <createTable tableName="jingles">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_jingles"/>
            </column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="voice" type="SMALLINT"><constraints nullable="false"/></column>
            <column name="category" type="SMALLINT"><constraints nullable="false"/></column>
            <column name="announcement_text" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="duration" type="BIGINT"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-4" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="music_types"/></not>
        </preConditions>
        <createTable tableName="music_types">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_music_types"/>
            </column>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="icon_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="preview_url" type="VARCHAR(255)"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-5" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="outgoing_requests"/></not>
        </preConditions>
        <createTable tableName="outgoing_requests">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_outgoing_requests"/>
            </column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="url" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="method" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="request_body" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="response_status_code" type="SMALLINT"><constraints nullable="false"/></column>
            <column name="response_body" type="VARCHAR(255)"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-6" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="stores"/></not>
        </preConditions>
        <createTable tableName="stores">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_stores"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="location" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(254)"><constraints nullable="false"/></column>
            <column defaultValueBoolean="false" name="active" type="boolean"><constraints nullable="false"/></column>
            <column name="music_link" type="varchar"/>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-7" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="users"/></not>
        </preConditions>
        <createTable tableName="users">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="company_name" type="VARCHAR(160)"><constraints nullable="false"/></column>
            <column name="business_type" type="VARCHAR(160)"><constraints nullable="false"/></column>
            <column name="music_provider" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="brand_identity" type="SMALLINT"><constraints nullable="false"/></column>
            <column name="current_feel" type="SMALLINT"><constraints nullable="false"/></column>
            <column name="space_purpose" type="VARCHAR(128)"><constraints nullable="false"/></column>
            <column name="playtime_window" type="VARCHAR(128)"><constraints nullable="false"/></column>
            <column defaultValueBoolean="false" name="onboarding_completed" type="boolean"><constraints nullable="false"/></column>
            <column name="password" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="role" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="email" type="VARCHAR(254)"><constraints nullable="false"/></column>
            <column defaultValueBoolean="false" name="email_verified" type="boolean"><constraints nullable="false"/></column>
            <column defaultValueBoolean="true" name="enabled" type="boolean"><constraints nullable="false"/></column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="company_role" type="VARCHAR(255)"/>
            <column name="music_type_id" type="BIGINT"/>
        </createTable>
    </changeSet>

    <changeSet id="1773986686936-8" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><uniqueConstraintExists constraintName="uc_music_types_name" tableName="music_types"/></not>
        </preConditions>
        <addUniqueConstraint columnNames="name" constraintName="uc_music_types_name" tableName="music_types"/>
    </changeSet>

    <changeSet id="1773986686936-9" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not><uniqueConstraintExists constraintName="uc_users_email" tableName="users"/></not>
        </preConditions>
        <addUniqueConstraint columnNames="email" constraintName="uc_users_email" tableName="users"/>
    </changeSet>

    <changeSet id="1773986686936-10" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_STORES_ON_USER" foreignKeyTableName="stores"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="stores" constraintName="FK_STORES_ON_USER"
                                 referencedColumnNames="id" referencedTableName="users"/>
    </changeSet>

    <changeSet id="1773986686936-11" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_USERS_ON_MUSIC_TYPE" foreignKeyTableName="users"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="music_type_id" baseTableName="users"
                                 constraintName="FK_USERS_ON_MUSIC_TYPE" referencedColumnNames="id"
                                 referencedTableName="music_types"/>
    </changeSet>

    <changeSet id="1773986686936-12" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_jinsto_on_jingle" foreignKeyTableName="jingle_stores"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="jingle_id" baseTableName="jingle_stores"
                                 constraintName="fk_jinsto_on_jingle" referencedColumnNames="id"
                                 referencedTableName="jingles"/>
    </changeSet>

    <changeSet id="1773986686936-13" author="Margulan">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_jinsto_on_store" foreignKeyTableName="jingle_stores"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint baseColumnNames="store_id" baseTableName="jingle_stores"
                                 constraintName="fk_jinsto_on_store" referencedColumnNames="id"
                                 referencedTableName="stores"/>
    </changeSet>

</databaseChangeLog>